# Roamio backend environment — copy to `.env` and fill in. Never commit the real `.env`.

# REQUIRED — the LLM (writer, faithfulness guard, tweak interpreter) + embeddings (RAG)
OPENAI_API_KEY=sk-...

# OPTIONAL — live road/weather conditions + the grounding-content top-up.
# Without it, the app still works; live-conditions just degrade gracefully.
TAVILY_API_KEY=tvly-...

# OPTIONAL — trip sharing (save-on-share -> /trip/[id]).
# Without these, generating/viewing trips works; only the share link is disabled.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-or-anon-key

# DEPLOY ONLY — comma-separated allowed browser origins for CORS (your Vercel URL).
# Local dev already allows localhost + private-LAN origins automatically.
# ALLOWED_ORIGINS=https://roamio.vercel.app

# FRONTEND (set in the Vercel project, not here) — the backend URL the browser calls.
# Local dev defaults to the page host on :8000, so this is only needed in production.
# NEXT_PUBLIC_API_URL=https://roamio-api.onrender.com
